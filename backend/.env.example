# Копия -> backend/.env (в git не попадает, см. .gitignore).
# Ключи и токены — только сюда, никогда не в код/логи/промпт LLM.

PORT=8200
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
JWP_DATA_DIR=/var/lib/jworkplace
CORS_ORIGINS=

# Токен-барьер публичного URL: nginx проверяет его на /api/* (кроме /api/health),
# redeploy.sh пробрасывает во фронт как VITE_API_TOKEN. Сгенерировать: openssl rand -hex 32.
# Это барьер от drive-by (в бандле фронта), НЕ секрет уровня API-ключа.
GATE_TOKEN=

# Ключ шифрования per-project GitHub PAT at rest (Fernet, Этап 3b). Сгенерировать:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Пусто/невалиден → функции токена/PR fail-closed (клон+индекс+чат+предпросмотр diff работают).
JWP_SECRET_KEY=

# --- Индексация (значения по умолчанию заданы в app/config.py, переопределять по надобности) ---
# OLLAMA_URL=http://127.0.0.1:11434
# EMBED_MODEL=nomic-embed-text
# MAX_REPO_MB=200
# MAX_FILES=5000
