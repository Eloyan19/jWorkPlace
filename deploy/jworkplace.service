[Unit]
Description=jWorkPlace backend — FastAPI code-assistant поверх произвольного GitHub-репо
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
WorkingDirectory=/root/repos/jWorkPlace/backend
EnvironmentFile=/root/repos/jWorkPlace/backend/.env
# Заполняется на деплое (см. deploy/README.md): короткий git-sha текущего релиза,
# попадает в GET /api/health -> version. Пусто -> version="dev".
Environment=GIT_SHA=
ExecStart=/root/repos/jWorkPlace/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8200
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
