# Корневой шаблон окружения jWorkPlace (документация).
# Рабочий файл backend читает из backend/.env — скопируй туда:
#   cp backend/.env.example backend/.env   и заполни значения.
# Секреты (DEEPSEEK_API_KEY, будущий GitHub PAT) — ТОЛЬКО в .env, никогда в git/логи/промпт LLM.
# .env покрыт .gitignore.

PORT=8200
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
JWP_DATA_DIR=/var/lib/jworkplace
CORS_ORIGINS=
